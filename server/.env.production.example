# SamuraCare Production Database Configuration
# Set these as environment variables in Hostinger Node.js config

DB_HOST=localhost
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=samuracare
DB_PORT=3306

# Server
PORT=8080

# JWT Secret - CHANGE THIS to a random string!
JWT_SECRET=replace-with-a-random-secret-string